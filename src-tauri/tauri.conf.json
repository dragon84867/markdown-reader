{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MD Reader",
  "version": "1.0.0",
  "identifier": "com.dragoncl.md-reader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MD Reader - Markdown 阅读器",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13"
    },
    "fileAssociations": [
      {
        "name": "Markdown",
        "description": "Markdown Document",
        "ext": ["md", "markdown"],
        "role": "Editor",
        "mimeType": "text/markdown"
      },
      {
        "name": "Text",
        "description": "Text Document",
        "ext": ["txt", "json", "yaml", "yml", "xml", "html", "css", "js", "ts", "vue", "py", "rs", "go", "java", "c", "cpp", "h", "sh", "bash", "zsh", "conf", "cfg", "ini", "log", "csv"],
        "role": "Viewer",
        "mimeType": "text/plain"
      }
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["file"]
      }
    }
  }
}
